# AI Configuration
USE_AI=True

# Provider chain. Primary is tried first; fallbacks (comma-separated) are
# tried in order on 503 / 429 / timeout. Providers without an API key are
# silently skipped.
AI_PROVIDER_PRIMARY=gemini
AI_PROVIDER_FALLBACKS=groq,openrouter

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (https://console.groq.com/keys) - 30K TPM, 1000 RPD on free tier
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenRouter (https://openrouter.ai/keys) - 50 RPD free, 1000 RPD with $10 credits
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-nano-9b-v2:free

# Resume Filter Settings
MIN_KEYWORD_SCORE=50
